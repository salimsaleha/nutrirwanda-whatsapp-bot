import os
import traceback

from flask import Flask, request, jsonify

from db import init_db, get_session
from models import User
from conversation import handle_message
import whatsapp

app = Flask(__name__)

VERIFY_TOKEN = os.environ.get("WHATSAPP_VERIFY_TOKEN", "changeme")

init_db()


@app.route("/", methods=["GET"])
def health():
    return jsonify({"status": "ok"})


@app.route("/webhook", methods=["GET"])
def verify_webhook():
    """Meta calls this once when you configure the webhook URL."""
    mode = request.args.get("hub.mode")
    token = request.args.get("hub.verify_token")
    challenge = request.args.get("hub.challenge")

    if mode == "subscribe" and token == VERIFY_TOKEN:
        return challenge, 200
    return "Forbidden", 403


@app.route("/webhook", methods=["POST"])
def incoming_webhook():
    signature = request.headers.get("X-Hub-Signature-256", "")
    if not whatsapp.verify_signature(request.get_data(), signature):
        return "Invalid signature", 403

    payload = request.get_json(force=True, silent=True) or {}
    wa_id, text, profile_name = whatsapp.extract_incoming_message(payload)

    if not wa_id:
        # Status update / non-text message webhook - acknowledge and ignore
        return jsonify({"status": "ignored"}), 200

    session = get_session()
    try:
        user = session.query(User).filter_by(wa_id=wa_id).first()
        if user is None:
            user = User(wa_id=wa_id, name=profile_name, state="NEW")
            session.add(user)
            session.flush()

        try:
            reply = handle_message(user, text)
        except Exception:
            traceback.print_exc()
            reply = (
                "Sorry, something went wrong on my end. Please try again, "
                "or reply 'update' to restart your profile."
            )

        session.commit()
        whatsapp.send_text(wa_id, reply)
    finally:
        session.close()

    return jsonify({"status": "received"}), 200


if __name__ == "__main__":
    port = int(os.environ.get("PORT", 5000))
    app.run(host="0.0.0.0", port=port, debug=False)
