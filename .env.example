# Copy this file to .env for local testing (Render/Railway: set these as dashboard env vars instead)

# --- Meta / WhatsApp Cloud API ---
WHATSAPP_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=pick_any_random_string_here
WHATSAPP_APP_SECRET=your_meta_app_secret
GRAPH_API_VERSION=v20.0

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-5

# --- Database ---
# Local dev default (no setup needed):
DATABASE_URL=sqlite:///local.db
# Production (Supabase Postgres, get this from Supabase project settings > Database):
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres

# --- Server ---
PORT=5000
