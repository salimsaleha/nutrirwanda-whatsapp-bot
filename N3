"""
Calorie & macro target calculations.

Uses the Mifflin-St Jeor equation (widely considered more accurate than
Harris-Benedict for modern populations) to estimate Basal Metabolic Rate,
then applies an activity multiplier to get Total Daily Energy Expenditure,
then adjusts the target based on the user's goal.

IMPORTANT: This produces general wellness estimates, not medical advice.
Anyone with a diagnosed illness (diabetes, kidney disease, severe
malnutrition/wasting, pregnancy complications, etc.) should be guided to
a doctor or registered dietitian in addition to using this tool.
"""

ACTIVITY_MULTIPLIERS = {
    "sedentary": 1.2,       # little/no exercise, desk-based
    "light": 1.375,         # light exercise 1-3 days/week
    "moderate": 1.55,       # moderate exercise 3-5 days/week
    "active": 1.725,        # hard exercise 6-7 days/week
    "very_active": 1.9,     # physical job + training
}

GOAL_ADJUSTMENTS = {
    "lose_weight": -500,        # ~0.5kg/week deficit
    "gain_weight": 500,         # ~0.5kg/week surplus
    "recover_malnutrition": 750, # higher surplus to rebuild reserves, should taper as weight normalizes
    "maintain": 0,
}

# Minimum safe floors so the bot never recommends a dangerously low target
MIN_CALORIES = {"female": 1200, "male": 1500}


def bmr_mifflin_st_jeor(sex: str, weight_kg: float, height_cm: float, age: int) -> float:
    """Mifflin-St Jeor BMR in kcal/day. sex: 'male' or 'female'."""
    base = (10 * weight_kg) + (6.25 * height_cm) - (5 * age)
    return base + 5 if sex == "male" else base - 161


def bmi(weight_kg: float, height_cm: float) -> float:
    h_m = height_cm / 100
    return round(weight_kg / (h_m ** 2), 1)


def bmi_category(bmi_value: float) -> str:
    if bmi_value < 16.0:
        return "severely underweight"
    if bmi_value < 18.5:
        return "underweight"
    if bmi_value < 25.0:
        return "normal weight"
    if bmi_value < 30.0:
        return "overweight"
    return "obese"


def suggest_goal_from_bmi(bmi_value: float) -> str:
    """Auto-suggest a goal if the user doesn't pick one, based on BMI."""
    if bmi_value < 18.5:
        return "gain_weight" if bmi_value >= 16.0 else "recover_malnutrition"
    if bmi_value >= 25.0:
        return "lose_weight"
    return "maintain"


def calorie_target(sex: str, weight_kg: float, height_cm: float, age: int,
                    activity_level: str, goal: str) -> dict:
    """Return dict with bmr, tdee, target_kcal, and macro split (g)."""
    bmr = bmr_mifflin_st_jeor(sex, weight_kg, height_cm, age)
    multiplier = ACTIVITY_MULTIPLIERS.get(activity_level, ACTIVITY_MULTIPLIERS["light"])
    tdee = bmr * multiplier
    adjustment = GOAL_ADJUSTMENTS.get(goal, 0)
    target = tdee + adjustment

    floor = MIN_CALORIES.get(sex, 1200)
    target = max(target, floor)

    # Macro split: 20% protein / 55% carbs / 25% fat as a general default,
    # shifted toward more protein for weight loss / malnutrition recovery.
    if goal in ("lose_weight",):
        protein_pct, carb_pct, fat_pct = 0.30, 0.40, 0.30
    elif goal in ("gain_weight", "recover_malnutrition"):
        protein_pct, carb_pct, fat_pct = 0.20, 0.55, 0.25
    else:
        protein_pct, carb_pct, fat_pct = 0.20, 0.50, 0.30

    protein_g = round((target * protein_pct) / 4)
    carbs_g = round((target * carb_pct) / 4)
    fat_g = round((target * fat_pct) / 9)

    return {
        "bmr": round(bmr),
        "tdee": round(tdee),
        "target_kcal": round(target),
        "protein_g": protein_g,
        "carbs_g": carbs_g,
        "fat_g": fat_g,
    }
